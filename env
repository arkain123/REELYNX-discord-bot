# ПЕРЕИМЕНОВАТЬ ДАННЫЙ ФАЙЛ В .env

# Discord bot токен
TOKEN=TOKEN_HERE

# Префикс команд. По умолчанию = !
PREFIX=!

# Уровень логирования ошибок. Доступные варианты: DEBUG, INFO, NOTICE, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к логу
LOG_FILE=/path/to/file

# ID категории где существует канал используемый для автосоздания приватных каналов
PRIVATE_VOICE_CATEGORY_ID=1111111111111111111

# ID каналов используемого для автосоздания приватных каналов
PRIVATE_VOICE_CHANNEL_IDS=1111111111111111111,1111111111111111111